# Frontend Environment Variables

PORT=3000
VITE_API_URL=http://localhost:3001/graphql
VITE_WS_URL=ws://localhost:3001/graphql
INTERNAL_API_URL=http://backend:3001/graphql

# ── API traffic encryption (optional, surface-level anti-scraping) ──
# When both are set at build time, lib/graphqlClient.ts wraps every
# GraphQL request body in `{ e: ciphertext }` and decrypts the response.
# Must match ENCRYPTION_KEY / ENCRYPTION_IV in the backend.
#   VITE_ENCRYPTION_KEY = 32 hex chars (256-bit AES key)
#   VITE_ENCRYPTION_IV  = 16 hex chars (128-bit IV)
VITE_ENCRYPTION_KEY=
VITE_ENCRYPTION_IV=
