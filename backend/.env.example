# Backend Environment Variables

PORT=3001
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000
RELOAD_SECRET=

# External Broken Arrow stats API
STATS_API_URL=https://api.brokenarrowgame.tech
STATS_PARTNER_TOKEN=

# ── API traffic encryption (optional, surface-level anti-scraping) ──
# When both are set, the GraphQL hooks at backend/src/index.ts decrypt
# incoming `{ e: ciphertext }` envelopes and re-encrypt their responses.
# Plaintext requests still pass through unchanged so GraphiQL keeps working.
# Must match VITE_ENCRYPTION_KEY / VITE_ENCRYPTION_IV in the frontend.
#   ENCRYPTION_KEY = 32 hex chars (256-bit AES key)
#   ENCRYPTION_IV  = 16 hex chars (128-bit IV)
ENCRYPTION_KEY=
ENCRYPTION_IV=
