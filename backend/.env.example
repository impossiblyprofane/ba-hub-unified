# Backend Environment Variables

PORT=3001
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000
RELOAD_SECRET=

# Set to 'true' to enable the stats crawler + snapshot collector.
# Keep 'false' in dev to avoid polluting the production database.
STATS_COLLECTION_ENABLED=false

# External Broken Arrow stats API
STATS_API_URL=https://api.brokenarrowgame.tech
STATS_PARTNER_TOKEN=
