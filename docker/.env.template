# BA Hub Unified — Docker Compose Environment Template
# Copy to .env and fill in values for your environment.
# CI/CD generates this file automatically from GitHub secrets.

# ── Project ──
COMPOSE_PROJECT_NAME=bahub-dev        # bahub-dev or bahub-prod
NODE_ENV=production

# ── Ports ──
PORT_FRONTEND=3000                     # dev: 3100, prod: 3000
PORT_BACKEND=3001                      # dev: 3101, prod: 3001
PORT_DATABASE=3002                     # dev: 3102, prod: 3002
PORT_POSTGRES=5432                     # dev: 5433, prod: 5432

# ── PostgreSQL ──
PG_USER=bahub
PG_PASSWORD=bahub_dev
PG_DB=bahub

# ── Frontend ──
VITE_API_URL=http://backend:3001/graphql
VITE_WS_URL=ws://backend:3001/graphql
SITE_URL=http://localhost:3000

# ── Backend ──
FRONTEND_URL=http://localhost:3000
STATS_API_URL=https://api.brokenarrowgame.tech
STATS_PARTNER_TOKEN=
# Optional override — backend has a built-in fallback Steam Web API key.
# Get your own at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
STATS_COLLECTION_ENABLED=true
RELOAD_SECRET=

# ── Match crawler tuning (all optional — sensible defaults otherwise) ──
# Top-N leaderboard players scanned for recent fight IDs (default 100)
CRAWLER_PLAYER_COUNT=
# IDs processed per range-scan chunk tick (default 15000)
CRAWLER_CHUNK_SIZE=
# Concurrent S3 fetches per batch (default 25)
CRAWLER_BATCH_SIZE=
# Milliseconds to wait between concurrent batches (default 40)
CRAWLER_BATCH_DELAY_MS=
# Range-scan tick interval in milliseconds (default 120000 = 2 minutes)
CRAWLER_INTERVAL_MS=

# Slow-request threshold in ms — requests above this land in the /sys slow ring (default 500)
SLOW_REQUEST_THRESHOLD_MS=

# ── Hidden /sys admin panel ──
# Random secret presented by the frontend at /sys. Leave empty to disable.
ADMIN_TOKEN=

# ── Database Admin Viewer ──
# Server-to-server bearer token for /api/admin/* on the database service.
# Required by the backend's /admin/db/* proxy used by the /sys panel.
DB_ADMIN_SECRET=
DB_ADMIN_ORIGINS=                      # Comma-separated origins for admin viewer CORS

# ── Encryption ──
ENCRYPT_API=false
ENCRYPTION_KEY=
ENCRYPTION_IV=
