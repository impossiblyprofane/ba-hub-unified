# BA Hub Unified — Docker Compose Environment Template
# Copy to .env and fill in values for your environment.
# CI/CD generates this file automatically from GitHub secrets.

# ── Project ──
COMPOSE_PROJECT_NAME=bahub-dev        # bahub-dev or bahub-prod
NODE_ENV=production

# ── Ports ──
PORT_FRONTEND=3000                     # dev: 3100, prod: 3000
PORT_BACKEND=3001                      # dev: 3101, prod: 3001
PORT_DATABASE=3002                     # dev: 3102, prod: 3002
PORT_POSTGRES=5432                     # dev: 5433, prod: 5432

# ── PostgreSQL ──
PG_USER=bahub
PG_PASSWORD=bahub_dev
PG_DB=bahub

# ── Frontend ──
VITE_API_URL=http://backend:3001/graphql
VITE_WS_URL=ws://backend:3001/graphql
SITE_URL=http://localhost:3000

# ── Backend ──
FRONTEND_URL=http://localhost:3000
STATS_API_URL=https://api.brokenarrowgame.tech
STATS_PARTNER_TOKEN=
STATS_COLLECTION_ENABLED=true
RELOAD_SECRET=

# ── Encryption ──
ENCRYPT_API=false
ENCRYPTION_KEY=
ENCRYPTION_IV=
